// ─────────────────────────────────────────────────────────────────
// Discovery Town — Prisma Schema (Backend Contract)
//
// PURPOSE: This schema defines the database contract for the backend.
// It is NOT used by the frontend at runtime. It serves as the
// single source of truth for backend developers to implement
// the API exactly as the frontend expects.
//
// CONVENTION: All fields use snake_case to match Raw*Response interfaces.
// Each field includes a traceability comment linking to its source.
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──

enum UserRole {
  user
  admin
  super_admin
}

enum MembershipType {
  standard
  member
  vip
}

enum BookingType {
  drop_in
  class_booking
  event
  party
}

enum BookingStatus {
  confirmed
  waitlisted
  cancelled
  completed
}

enum ClassCategory {
  art
  music
  movement
  stem
  language
}

enum PartyAddOnPricingModel {
  flat
  per_person
}

enum CommerceCategory {
  gift
  rental
  shop
}

enum OrderStatus {
  received
  confirmed
  processing
}

enum FulfillmentType {
  pickup
  delivery
}

// ── Models ──

/// Source: RawLoginResponse.user + RawProfileResponse
model User {
  id              String         @id @default(uuid())
  email           String         @unique             // Source: RawProfileResponse.email
  name            String                             // Source: RawLoginResponse.user.name
  first_name      String                             // Source: RawProfileResponse.first_name
  last_name       String                             // Source: RawProfileResponse.last_name
  phone           String?                            // Source: RawProfileResponse.phone
  role            UserRole       @default(user)      // Source: RawLoginResponse.user.role
  membership_type MembershipType @default(standard)  // Source: RawProfileResponse.membership_type
  member_since    DateTime       @default(now())     // Source: RawProfileResponse.member_since
  password_hash   String                             // Backend-only: never exposed
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  children        ChildProfile[]
  bookings        Booking[]
  commerce_orders CommerceOrder[]

  @@map("users")
}

/// Source: RawProfileResponse.children
model ChildProfile {
  id            String   @id @default(uuid())
  user_id       String                          // Foreign key to User
  name          String                          // Source: RawProfileResponse.children[].name
  date_of_birth String                          // Source: RawProfileResponse.children[].date_of_birth
  allergies     String   @default("")           // Source: RawProfileResponse.children[].allergies
  notes         String   @default("")           // Source: RawProfileResponse.children[].notes
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("child_profiles")
}

/// Source: RawBookingResponse
model Booking {
  id                String        @id @default(uuid())
  user_id           String                                  // Foreign key to User
  booking_type      BookingType                             // Source: RawBookingResponse.booking_type
  title             String                                  // Source: RawBookingResponse.title
  scheduled_date    String                                  // Source: RawBookingResponse.scheduled_date
  time_range        String                                  // Source: RawBookingResponse.time_range
  status            BookingStatus @default(confirmed)       // Source: RawBookingResponse.status
  total_amount      Float         @default(0)               // Source: RawBookingResponse.total_amount
  confirmation_code String        @unique                   // Source: RawBookingResponse.confirmation_code
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  user              User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  guests            BookingGuest[]

  @@map("bookings")
}

/// Source: RawBookingResponse.guests[]
model BookingGuest {
  id           String  @id @default(uuid())
  booking_id   String                          // Foreign key to Booking
  full_name    String                          // Source: RawBookingResponse.guests[].full_name
  age          Int                             // Source: RawBookingResponse.guests[].age
  relationship String                          // Source: RawBookingResponse.guests[].relationship

  booking      Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("booking_guests")
}

/// Source: RawTimeSlotResponse
model TimeSlot {
  id              String   @id @default(uuid())
  date            String                         // Source: RawTimeSlotResponse.date
  start_time      String                         // Source: RawTimeSlotResponse.start_time
  end_time        String                         // Source: RawTimeSlotResponse.end_time
  spots_total     Int                            // Source: RawTimeSlotResponse.spots_total
  spots_available Int                            // Source: RawTimeSlotResponse.spots_available
  price_per_child Float                          // Source: RawTimeSlotResponse.price_per_child
  age_min         Int                            // Source: RawTimeSlotResponse.age_min
  age_max         Int                            // Source: RawTimeSlotResponse.age_max
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("time_slots")
}

/// Source: RawClassEventResponse
model ClassEvent {
  id                String        @id @default(uuid())
  title             String                              // Source: RawClassEventResponse.title
  description       String                              // Source: RawClassEventResponse.description
  instructor        String                              // Source: RawClassEventResponse.instructor
  category          ClassCategory                       // Source: RawClassEventResponse.category
  schedule          String                              // Source: RawClassEventResponse.schedule
  duration          Int                                 // Source: RawClassEventResponse.duration
  spots_total       Int                                 // Source: RawClassEventResponse.spots_total
  spots_available   Int                                 // Source: RawClassEventResponse.spots_available
  price_per_session Float                               // Source: RawClassEventResponse.price_per_session
  price_series      Float                               // Source: RawClassEventResponse.price_series
  age_min           Int                                 // Source: RawClassEventResponse.age_min
  age_max           Int                                 // Source: RawClassEventResponse.age_max
  image_slug        String                              // Source: RawClassEventResponse.image_slug
  tags              String[]                            // Source: RawClassEventResponse.tags
  start_date        String                              // Source: RawClassEventResponse.start_date
  end_date          String                              // Source: RawClassEventResponse.end_date
  sessions_total    Int                                 // Source: RawClassEventResponse.sessions_total
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  @@map("class_events")
}

/// Source: RawSpecialEventResponse
model SpecialEvent {
  id               String        @id @default(uuid())
  title            String                              // Source: RawSpecialEventResponse.title
  description      String                              // Source: RawSpecialEventResponse.description
  featured         Boolean       @default(false)       // Source: RawSpecialEventResponse.featured
  location         String                              // Source: RawSpecialEventResponse.location
  image_slug       String                              // Source: RawSpecialEventResponse.image_slug
  tags             String[]                            // Source: RawSpecialEventResponse.tags
  max_capacity     Int                                 // Source: RawSpecialEventResponse.max_capacity
  registered_count Int           @default(0)           // Source: RawSpecialEventResponse.registered_count
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  dates            EventDay[]
  pricing_tiers    PricingTier[]

  @@map("special_events")
}

/// Source: RawEventDayResponse
model EventDay {
  id               String       @id @default(uuid())
  special_event_id String                               // Foreign key to SpecialEvent
  date             String                               // Source: RawEventDayResponse.date
  start_time       String                               // Source: RawEventDayResponse.start_time
  end_time         String                               // Source: RawEventDayResponse.end_time
  activities       String[]                             // Source: RawEventDayResponse.activities

  special_event    SpecialEvent @relation(fields: [special_event_id], references: [id], onDelete: Cascade)

  @@map("event_days")
}

/// Source: RawPricingTierResponse
model PricingTier {
  id               String       @id @default(uuid())
  special_event_id String                               // Foreign key to SpecialEvent
  label            String                               // Source: RawPricingTierResponse.label
  price            Float                                // Source: RawPricingTierResponse.price
  perks            String[]                             // Source: RawPricingTierResponse.perks
  spots_available  Int                                  // Source: RawPricingTierResponse.spots_available

  special_event    SpecialEvent @relation(fields: [special_event_id], references: [id], onDelete: Cascade)

  @@map("pricing_tiers")
}

/// Source: RawPartyPackageResponse
model PartyPackage {
  id                   String     @id @default(uuid())
  name                 String                                // Source: RawPartyPackageResponse.name
  tagline              String                                // Source: RawPartyPackageResponse.tagline
  price                Float                                 // Source: RawPartyPackageResponse.price
  deposit_amount       Float                                 // Source: RawPartyPackageResponse.deposit_amount
  duration             Int                                   // Source: RawPartyPackageResponse.duration
  guests_included      Int                                   // Source: RawPartyPackageResponse.guests_included
  price_per_extra_guest Float                                // Source: RawPartyPackageResponse.price_per_extra_guest
  features             String[]                              // Source: RawPartyPackageResponse.features
  color                String                                // Source: RawPartyPackageResponse.color
  popular              Boolean    @default(false)             // Source: RawPartyPackageResponse.popular
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  add_ons              PartyAddOn[]

  @@map("party_packages")
}

/// Source: RawPartyAddOnResponse
model PartyAddOn {
  id               String                  @id @default(uuid())
  party_package_id String                                         // Foreign key to PartyPackage
  label            String                                         // Source: RawPartyAddOnResponse.label
  price            Float                                          // Source: RawPartyAddOnResponse.price
  description      String                                         // Source: RawPartyAddOnResponse.description
  pricing_model    PartyAddOnPricingModel                          // Source: RawPartyAddOnResponse.pricing_model

  party_package    PartyPackage            @relation(fields: [party_package_id], references: [id], onDelete: Cascade)

  @@map("party_add_ons")
}

/// Source: RawCommerceItemResponse
model CommerceItem {
  id            String           @id @default(uuid())
  slug          String           @unique                // Source: RawCommerceItemResponse.slug
  name          String                                  // Source: RawCommerceItemResponse.name
  price         String                                  // Source: RawCommerceItemResponse.price
  description   String                                  // Source: RawCommerceItemResponse.description
  image_url     String                                  // Source: RawCommerceItemResponse.image_url
  accent_color  String                                  // Source: RawCommerceItemResponse.accent_color
  soft_bg       String                                  // Source: RawCommerceItemResponse.soft_bg
  border_color  String                                  // Source: RawCommerceItemResponse.border_color
  category      CommerceCategory                        // Source: RawCommerceItemResponse.category
  section_label String                                  // Source: RawCommerceItemResponse.section_label
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  @@map("commerce_items")
}

/// Source: RawOrderConfirmationResponse
model CommerceOrder {
  id          String          @id @default(uuid())
  user_id     String                                    // Foreign key to User
  item_slug   String                                    // Reference to CommerceItem.slug
  category    CommerceCategory                          // Order category
  quantity    Int             @default(1)
  fulfillment FulfillmentType
  date        String
  time        String
  address     String?
  notes       String?
  name        String
  email       String
  phone       String
  status      OrderStatus     @default(received)        // Source: RawOrderConfirmationResponse.status
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("commerce_orders")
}
